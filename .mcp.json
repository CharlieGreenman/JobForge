{
  "mcpServers": {
    "geometra": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@geometra/mcp"
      ],
      "env": {}
    },
    "gmail": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
